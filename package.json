{
  "name": "hsr-optimizer",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://fribbels.github.io/hsr-optimizer",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=999.0.0",
    "yarn": ">=999.0.0"
  },
  "scripts": {
    "start": "vite",
    "start:prod": "vite build && vite preview",
    "build": "vite build",
    "lint": "oxlint",
    "vitest": "vitest --dir src/lib --no-watch --pool=threads",
    "vitest:fast": "vitest --dir src/lib --no-watch --pool=threads --exclude '**/simulations/tests/**/*Orchestrator*' --exclude '**/simulations/tests/goldenData/**'",
    "vitest:silent": "vitest --dir src/lib --no-watch --pool=threads --silent",
    "bench:simbuild:generate": "vitest run src/lib/simulations/tests/goldenData/generateSimBuildGoldenData.test.ts --reporter=verbose",
    "bench:simbuild:verify": "vitest run src/lib/simulations/tests/goldenData/verifySimBuildGoldenData.test.ts --reporter=verbose",
    "bench:dps:generate": "vitest run src/lib/simulations/tests/goldenData/generateDpsScoreGoldenData.test.ts --reporter=verbose",
    "bench:dps:verify": "vitest run src/lib/simulations/tests/goldenData/verifyDpsScoreGoldenData.test.ts --reporter=verbose",
    "bench:searchtree": "vitest run src/lib/worker/maxima/tree/tests/searchTreeBenchmark.test.ts --reporter=verbose",
    "bench:pipeline": "vitest run src/lib/simulations/tests/goldenData/benchmarkDpsScorePipeline.test.ts --reporter=verbose",
    "vitest:watch": "vitest --dir src/lib --watch",
    "test": "npx playwright test --config tests/playwright.config.ts --trace on",
    "test:generate": "npx playwright codegen localhost:3000/hsr-optimizer",
    "test:ui": "npm run test -- --ui",
    "test:report": "npx playwright show-report",
    "typecheck": "npm run update-resources && tsc --noEmit -p ./tsconfig.json",
    "typecheck:fast": "tsc --noEmit -p ./tsconfig.fast.json",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "update-resources": "npx i18next-resources-for-ts interface -i ./public/locales/en_US -o ./src/types/resources.d.ts"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@esotericsoftware/spine-webgl": "4.1.23",
    "@mantine/core": "^9.0.0-alpha.4",
    "@mantine/dropzone": "^9.0.0-alpha.4",
    "@mantine/form": "^9.0.0-alpha.4",
    "@mantine/hooks": "^9.0.0-alpha.4",
    "@mantine/modals": "^9.0.0-alpha.4",
    "@mantine/notifications": "^9.0.0-alpha.4",
    "@tabler/icons-react": "^3.40.0",
    "ag-grid-community": "^35.0.0",
    "ag-grid-react": "^35.0.0",
    "chroma-js": "^3.2.0",
    "colorthief": "^3.3.1",
    "html-to-image": "^1.11.13",
    "i18next": "^23.14.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^2.6.1",
    "js-yaml": "^4.1.1",
    "node-vibrant": "^3.1.6",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6",
    "partysocket": "^1.1.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^15.0.1",
    "react-selecto": "^1.26.3",
    "recharts": "^3.8.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chroma-js": "^3.1.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@webgpu/types": "^0.1.69",
    "dprint": "^0.52.0",
    "gh-pages": "^6.3.0",
    "i18next-resources-for-ts": "^1.5.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.54.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@jimp/core": {
      "phin": "3.7.1"
    },
    "selecto": {
      "@daybrush/utils": "1.13.0",
      "framework-utils": "1.1.0"
    },
    "@esotericsoftware/spine-core": "4.1.23"
  }
}
